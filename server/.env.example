# ==============================
# Sahayak Server - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ==============================

# MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/sahayak

# JWT secret — use a long, random string (min 32 chars)
JWT_SECRET=your_very_long_random_jwt_secret_here

# Razorpay credentials (get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (Nodemailer) — use an App Password, not your real password
USER_EMAIL=your_email@gmail.com
USER_PASSWORD=your_gmail_app_password

# Admin email (used for admin seeding)
ADMIN_EMAIL=admin@yourdomain.com

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Server port
PORT=3000
